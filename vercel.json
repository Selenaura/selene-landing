{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/stripe-webhook",
      "methods": ["POST"],
      "dest": "/api/stripe-webhook.js"
    },
    {
      "src": "/api/admin-data",
      "methods": ["GET"],
      "dest": "/api/admin-data.js"
    },
    {
      "src": "/api/email-funnel",
      "methods": ["GET", "POST"],
      "dest": "/api/email-funnel.js"
    },
    {
      "src": "/api/weekly-horoscope",
      "methods": ["GET"],
      "dest": "/api/weekly-horoscope.js"
    },
    {
      "src": "/api/compatibilidad",
      "methods": ["POST"],
      "dest": "/api/compatibilidad.js"
    },
    {
      "src": "/api/re-engage",
      "methods": ["GET"],
      "dest": "/api/re-engage.js"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    }
  ],
  "crons": [
    {
      "path": "/api/email-funnel",
      "schedule": "0 */2 * * *"
    }
  ]
}
